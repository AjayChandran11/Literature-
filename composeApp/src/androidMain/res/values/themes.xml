<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme: DayNight + correct window background to prevent flash -->
    <style name="Theme.Literature" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash screen theme: transitions to Theme.Literature after launch -->
    <style name="Theme.Literature.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/app_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.Literature</item>
    </style>
</resources>
